{{ define "modules/article/html/search" }}
    {{ template "templates/layouts/html/head" .}}
    {{ template "templates/layouts/html/navbar" .}}
    <!-- 音乐风格搜索结果页面 -->
    <div class="music-search-container">
        <div class="container">
            <div class="section-title">
                <h2 class="music-section-title">
                    <i class="fas fa-search"></i>
                    <span>{{ if .keyword }}搜索结果: "{{ .keyword }}"{{ else }}请输入搜索关键词{{ end }}</span>
                </h2>
                <div class="search-form">
                    <form action="/search" method="GET">
                        <div class="search-input-group">
                            <input type="text" name="keyword"
                                value="{{ .keyword }}"
                                placeholder="搜索文章..."
                                required>
                            <button type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            {{ if .keyword }}
            <div class="row">
                {{ range .articles.Data }}
                <div class="col-md-4 col-sm-6 mb-4">
                    <div class="music-card">
                        <a href="/articles/{{ .ID }}">
                            <div class="article-image" style="background-image:url({{ .Image }});">
                                <div class="vinyl-overlay">
                                    <div class="vinyl-center"></div>
                                </div>
                            </div>
                        </a>
                        <div class="card-block">
                            <h2 class="card-title"><a href="/articles/{{ .ID }}">{{ .Title }}</a></h2>
                            <div class="card-text article-excerpt">{{ .Content }}</div>
                            <div class="metafooter">
                                <div class="wrapfooter">
                                    <span class="meta-footer-thumb">
                                        <a href="#"><img class="author-thumb" src="{{ .User.Image }}" alt="{{ .User.Name }}"></a>
                                    </span>
                                    <span class="author-meta">
                                        <span class="post-name"><a href="#">{{ .User.Name }}</a></span><br/>
                                        <span class="post-date">{{ .CreatedAt }}</span>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {{ else }}
                <div class="col-12">
                    <div class="no-results">
                        <i class="fas fa-music"></i>
                        <p>没有找到包含 "{{ .keyword }}" 的文章</p>
                        <small>试试其他关键词？</small>
                    </div>
                </div>
                {{ end }}
            </div>
            {{ end }}
        </div>
    </div>

    <style>
    .music-search-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #1e2024 0%, #18181d 100%);
        padding: 40px 20px;
    }

    .music-section-title {
        text-align: center;
        color: #fff;
        margin-bottom: 40px;
        font-size: 2em;
        text-shadow: 0 0 10px rgba(255,255,255,0.3);
    }

    .music-section-title i {
        margin-right: 10px;
        color: #ff6b6b;
    }

    .music-card {
        background: rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        backdrop-filter: blur(10px);
        margin-bottom: 30px;
        overflow: hidden;
        transition: all 0.3s ease;
        border: none;
        height: 100%;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .music-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }

    .article-image {
        width: 100%;
        padding-top: 66.67%;
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .vinyl-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(circle at center, transparent 30%, rgba(0,0,0,0.2) 31%, transparent 32%);
        opacity: 0;
        transition: all 0.3s ease;
    }

    .music-card:hover .vinyl-overlay {
        opacity: 1;
    }

    .vinyl-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 30px;
        height: 30px;
        background: #ff6b6b;
        border-radius: 50%;
        box-shadow: 0 0 20px rgba(255,107,107,0.5);
    }

    .card-block {
        padding: 20px;
    }

    .card-title {
        margin-bottom: 15px;
    }

    .card-title a {
        color: rgba(255, 255, 255, 0.95);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 1.2em;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-weight: 600;
    }

    .article-excerpt {
        color: rgba(255,255,255,0.85);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.5;
        margin-bottom: 15px;
        font-size: 0.9em;
        height: 4.5em;
    }

    .metafooter {
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: 15px;
        margin-top: auto;
        font-size: 0.85em;
    }

    .wrapfooter {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .author-meta {
        color: rgba(255,255,255,0.8);
    }

    .post-date {
        color: rgba(255,255,255,0.75);
    }

    .author-thumb {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 2px solid #ff6b6b;
        object-fit: cover;
    }

    .no-results {
        text-align: center;
        padding: 60px 20px;
        color: rgba(255,255,255,0.7);
    }

    .no-results i {
        font-size: 48px;
        margin-bottom: 20px;
        color: #ff6b6b;
    }

    .no-results p {
        font-size: 1.2em;
    }

    @media (max-width: 768px) {
        .music-section-title {
            font-size: 1.5em;
        }
    }

    .search-form {
        max-width: 600px;
        margin: 30px auto;
    }

    .search-input-group {
        display: flex;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 30px;
        padding: 5px;
    }

    .search-input-group input {
        flex: 1;
        background: transparent;
        border: none;
        padding: 15px 20px;
        color: #fff;
        font-size: 16px;
    }

    .search-input-group input::placeholder {
        color: rgba(255, 255, 255, 0.6);
    }

    .search-input-group input:focus {
        outline: none;
    }

    .search-input-group button {
        background: linear-gradient(45deg, #ff6b6b, #ff8e8e);
        border: none;
        border-radius: 25px;
        padding: 12px 25px;
        color: #fff;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .search-input-group button:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255,107,107,0.4);
    }

    .no-results small {
        display: block;
        margin-top: 10px;
        font-size: 0.9em;
        opacity: 0.7;
    }
    </style>

    {{ template "templates/layouts/html/footer" .}}
    {{ template "templates/layouts/html/foot" .}}
{{ end }}