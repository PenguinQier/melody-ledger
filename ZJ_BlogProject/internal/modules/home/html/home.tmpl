{{ define "modules/home/html/home" }}
    {{ template "templates/layouts/html/head" .}}
    {{ template "templates/layouts/html/header" .}}
    {{ template "templates/layouts/html/navbar" .}}
    <!-- 音乐风格首页 -->
    <div class="music-home-container">
        <!-- Begin Featured -->
        <section class="featured-posts">
            <div class="section-title">
                <h2 class="music-section-title">
                    <i class="fas fa-star"></i>
                    <span>推荐歌单</span>
                </h2>
            </div>
            <div class="card-columns listfeaturedtag">
                {{ range .featured.Data }}
                <!-- 开始文章卡片 -->
                <div class="music-card">
                    <div class="row">
                        <div class="col-md-5 wrapthumbnail">
                            <a href="/articles/{{ .ID }}">
                                <div class="thumbnail" style="background-image:url({{ .Image }}); padding-top: 66.67%;">
                                    <div class="vinyl-overlay">
                                        <div class="vinyl-center"></div>
                                    </div>
                                </div>
                            </a>
                        </div>
                        <div class="col-md-7">
                            <div class="card-block">
                                <h2 class="card-title"><a href="/articles/{{ .ID }}">{{ .Title }}</a></h2>
                                <h4 class="card-text article-excerpt">{{ .Content }}</h4>
                                <div class="metafooter">
                                    <div class="wrapfooter">
                                        <span class="meta-footer-thumb">
                                            <a href="#"><img class="author-thumb" src="{{ .User.Image }}" alt="作者头像"></a>
                                        </span>
                                        <span class="author-meta">
                                            <span class="post-name"><a href="#">{{ .User.Name }}</a></span><br/>
                                            <span class="post-date">{{ .CreatedAt }}</span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 结束文章卡片 -->
                {{ end }}
            </div>
        </section>

        <!-- Begin List Posts -->
        <section class="recent-posts">
            <div class="section-title">
                <h2 class="music-section-title">
                    <i class="fas fa-music"></i>
                    <span>最新发布</span>
                </h2>
            </div>
            <div class="card-columns listrecent">
                {{ range .stories.Data }}
                <!-- begin post -->
                <div class="music-card">
                    <div class="row">
                        <div class="col-md-5 wrapthumbnail">
                            <a href="/articles/{{ .ID }}">
                                <div class="thumbnail" style="background-image:url({{ .Image }}); padding-top: 66.67%;">
                                    <div class="vinyl-overlay">
                                        <div class="vinyl-center"></div>
                                    </div>
                                </div>
                            </a>
                        </div>
                        <div class="col-md-7">
                            <div class="card-block">
                                <h2 class="card-title"><a href="/articles/{{ .ID }}">{{ .Title }}</a></h2>
                                <h4 class="card-text article-excerpt">{{ .Content }}</h4>
                                <div class="metafooter">
                                    <div class="wrapfooter">
                                        <span class="meta-footer-thumb">
                                            <a href="#"><img class="author-thumb" src="{{ .User.Image }}" alt="{{ .User.Name }}"></a>
                                        </span>
                                        <span class="author-meta">
                                            <span class="post-name"><a href="#">{{ .User.Name }}</a></span><br/>
                                            <span class="post-date">{{ .CreatedAt }}</span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- end post -->
                {{ end }}
            </div>
        </section>
    </div>

    <style>
    .music-home-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #1e2024 0%, #18181d 100%);
        padding: 80px 20px 40px;
        margin-top: -24px;
        margin-bottom: -60px;
    }

    .music-section-title {
        text-align: center;
        color: #fff;
        margin: 0 0 40px;
        font-size: 2em;
        text-shadow: 0 0 10px rgba(255,255,255,0.3);
    }

    .music-section-title i {
        margin-right: 10px;
        color: #ff6b6b;
    }

    .music-card {
        background: rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        backdrop-filter: blur(10px);
        margin-bottom: 30px;
        overflow: hidden;
        transition: all 0.3s ease;
        border: none;
        height: 100%;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .music-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }

    .story-card {
        background: rgba(255, 255, 255, 0.1);
    }

    .wrapthumbnail {
        padding: 0;
        height: 100%;
    }

    .wrapthumbnail a {
        display: block;
        height: 100%;
    }

    .thumbnail {
        position: relative;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 15px 0 0 15px;
        overflow: hidden;
        height: 100%;
        min-height: 250px;
        padding-top: 0 !important;
    }

    .music-card .row {
        margin: 0;
        height: 100%;
    }

    .music-card .col-md-7 {
        padding: 20px;
    }

    .music-card .col-md-5 {
        padding: 0;
    }

    @media (max-width: 767px) {
        .thumbnail {
            border-radius: 15px 15px 0 0;
            min-height: 200px;
        }

        .music-card .col-md-7 {
            padding: 15px;
        }
    }

    .vinyl-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(circle at center, transparent 30%, rgba(0,0,0,0.2) 31%, transparent 32%);
        opacity: 0;
        transition: all 0.3s ease;
    }

    .music-card:hover .vinyl-overlay {
        opacity: 1;
    }

    .vinyl-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 30px;
        height: 30px;
        background: #ff6b6b;
        border-radius: 50%;
        box-shadow: 0 0 20px rgba(255,107,107,0.5);
    }

    .card-title a {
        color: rgba(255, 255, 255, 0.95);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 1.2em;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-weight: 600;
    }

    .card-title a:hover {
        color: #ff6b6b;
    }

    .article-excerpt {
        color: rgba(255,255,255,0.85);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.5;
        margin-bottom: 15px;
        font-size: 0.9em;
        height: 4.5em;
    }

    .metafooter {
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: 15px;
        margin-top: auto;
        font-size: 0.85em;
    }

    .author-meta {
        color: rgba(255,255,255,0.8);
    }

    .post-date, .post-read {
        color: rgba(255,255,255,0.75);
    }

    .author-thumb {
        border-radius: 50%;
        border: 2px solid #ff6b6b;
        width: 40px;
        height: 40px;
        object-fit: cover;
    }

    @media (max-width: 768px) {
        .music-section-title {
            font-size: 1.5em;
        }
    }

    .card-columns {
        @media (min-width: 992px) {
            column-count: 3;
            column-gap: 1.25rem;
        }
        @media (min-width: 768px) and (max-width: 991px) {
            column-count: 2;
        }
        @media (max-width: 767px) {
            column-count: 1;
        }
    }

    .listfeaturedtag .card-columns {
        column-count: 1;
    }

    .wrapfooter {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    </style>

    {{ template "templates/layouts/html/footer" .}}
    {{ template "templates/layouts/html/foot" .}}
{{ end }}