{{ define "templates/layouts/html/footer" }}
    <!-- Begin Footer -->
    <div class="music-footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-wave">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320">
                        <path fill="currentColor" d="M0,96L48,112C96,128,192,160,288,186.7C384,213,480,235,576,213.3C672,192,768,128,864,128C960,128,1056,192,1152,208C1248,224,1344,192,1392,176L1440,160L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
                    </svg>
                </div>
                <div class="footer-info">
                    <p class="footer-copyright">
                        版权 &copy; 2024 {{ .APP_NAME }}
                    </p>
                    <p class="footer-credit">
                        主题由 <a target="_blank" href="https://www.wowthemes.net">WowThemes.net</a>提供
                    </p>
                    <div class="footer-social">
                        <a href="#" class="social-icon"><i class="fab fa-github"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-weibo"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
    .music-footer {
        position: relative;
        background: rgba(30, 32, 36, 0.95);
        color: rgba(255, 255, 255, 0.8);
        padding: 60px 0 30px;
        margin-top: 0;
        overflow: hidden;
    }

    .footer-wave {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 120px;
        color: rgba(30, 32, 36, 0.95);
        transform: translateY(-99%);
    }

    .footer-wave svg {
        display: block;
        width: 100%;
        height: 100%;
    }

    .footer-content {
        position: relative;
        z-index: 1;
    }

    .footer-info {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }

    .footer-copyright, .footer-credit {
        margin: 0;
        font-size: 0.9em;
    }

    .footer-credit a {
        color: #ff6b6b;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .footer-credit a:hover {
        color: #ff8e8e;
    }

    .footer-social {
        display: flex;
        gap: 15px;
    }

    .social-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        color: rgba(255, 255, 255, 0.8);
        transition: all 0.3s ease;
    }

    .social-icon:hover {
        background: #ff6b6b;
        color: #fff;
        transform: translateY(-3px);
    }

    @media (max-width: 768px) {
        .footer-info {
            flex-direction: column;
            text-align: center;
        }

        .footer-social {
            margin-top: 20px;
        }
    }
    </style>

{{ end }}